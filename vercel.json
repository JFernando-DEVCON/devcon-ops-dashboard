{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 2 * * 1-5"
    },
    {
      "path": "/api/scout",
      "schedule": "0 2 * * 1"
    }
  ]
}
